# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Fine-tuned model IDs — find these in the OpenAI dashboard under Fine-tuning
OPENAI_FT_MODEL_WITHOUT_BFPT=ft:gpt-4o-...:your-model-id
OPENAI_FT_MODEL_WITH_BFPT=ft:gpt-4o-...:your-model-id

# Training file ID — find this in the OpenAI dashboard under Storage
OPENAI_TRAINING_FILE_ID=file-...
